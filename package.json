{
  "name": "immersive-ai-translate",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "npm run build:local-debug",
    "build:local-debug": "BUILD_OUT_DIR=dist-local-debug VITE_EXTENSION_DEBUG_LOGS=true vite build",
    "package:release": "VITE_RELEASE_BUILD=true VITE_DEFAULT_DEEPSEEK_API_KEY= VITE_EXTENSION_DEBUG_LOGS=false npm run build && mkdir -p releases && VERSION=$(node -p \"JSON.parse(require('fs').readFileSync('package.json', 'utf8')).version\") && ZIP=\"releases/immersive-ai-translate-v$VERSION.zip\" && rm -f \"$ZIP\" && zip -qr \"$ZIP\" dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:deepseek-smoke": "playwright test tests/e2e/deepseek-smoke.spec.ts"
  },
  "dependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.325",
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
