{
  "manifest_version": 3,
  "name": "Immersive AI Translate",
  "version": "0.2.1",
  "key": "",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-B07eALlL.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/pdf/index.html",
        "assets/settings-aoFaOosX.js",
        "assets/debug-CwimSA1n.js",
        "assets/index.ts-1oy_FMyA.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
